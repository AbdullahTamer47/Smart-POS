# ============================================================
# Smart POS Next — Environment Variables
# ============================================================
# Copy this to .env and fill in values

# ---- Node ----
NODE_ENV=development
PORT=3001

# ---- Database ----
DATABASE_URL=postgresql://smartpos:smartpos@localhost:5432/smartpos?schema=public
DATABASE_URL_DIRECT=postgresql://smartpos:smartpos@localhost:5432/smartpos
PGBOUNCER_URL=postgresql://smartpos:smartpos@pgbouncer:6432/smartpos

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Bcrypt ----
BCRYPT_ROUNDS=12

# ---- CORS ----
CORS_ORIGIN=http://localhost:5173

# ---- API ----
API_PREFIX=api/v1
API_URL=http://localhost:3001

# ---- Frontend ----
VITE_API_URL=/api/v1
VITE_WS_URL=ws://localhost:3001
VITE_APP_NAME=Smart POS
VITE_DEFAULT_LANGUAGE=ar
VITE_DEFAULT_THEME=light

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=smart-pos

# ---- AWS S3 ----
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- Email (SMTP) ----
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@smartpos.com

# ---- Sentry ----
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---- Twilio (WhatsApp) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ---- Paymob ----
PAYMOB_API_KEY=
PAYMOB_IFRAME_ID=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC_SECRET=

# ---- Fawry ----
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=

# ---- ZATCA ----
ZATCA_CSID=
ZATCA_PRODUCTION_CSID=
ZATCA_ENVIRONMENT=sandbox
ZATCA_CERT_PATH=
ZATCA_PRIVATE_KEY_PATH=

# ---- Exchange Rate API ----
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest

# ---- Rate Limiting ----
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_PER_TENANT_TTL=60000
RATE_LIMIT_PER_TENANT_MAX=500

# ---- Feature Flags ----
DEFAULT_FEATURES=offline_mode,analytics,api_access

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# ---- Docker ----
COMPOSE_PROJECT_NAME=smartpos
POSTGRES_USER=smartpos
POSTGRES_PASSWORD=smartpos
POSTGRES_DB=smartpos